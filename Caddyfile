localhost:8080 {
    reverse_proxy /api/* api:3000
    reverse_proxy /socket.io/* api:3000
    reverse_proxy /ntfy/* ntfy:80
    reverse_proxy /uploads/* api:3000
    # For dev without HTTPS
    # Production would use a real domain with Let's Encrypt
}

